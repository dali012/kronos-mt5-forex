# Copy to .env and fill in. NEVER commit the real .env.

# --- MetaTrader 5 DEMO account ---
MT5_LOGIN=00000000
MT5_PASSWORD=changeme
MT5_SERVER=YourBroker-Demo          # must be a DEMO server
MT5_TERMINAL_PATH=                  # optional: path to terminal64.exe

# --- Instrument / timeframe ---
TRADING_SYMBOL=EURUSD
BAR_SPEC=15-MINUTE-LAST             # NautilusTrader bar spec

# --- Kronos brain ---
KRONOS_TOKENIZER=NeoQuasar/Kronos-Tokenizer-base
KRONOS_MODEL=NeoQuasar/Kronos-small
KRONOS_DEVICE=cpu                  # cpu | cuda:0
KRONOS_MAX_CONTEXT=512
LOOKBACK=400                       # <= max_context
PRED_LEN=12                        # forecast horizon in bars
SAMPLE_COUNT=10                    # probabilistic sampling paths
KRONOS_T=1.0
KRONOS_TOP_P=0.9

# --- Signal / risk ---
SIGNAL_THRESHOLD_BPS=8             # min expected move over horizon, in basis points, ON TOP of cost
RISK_PER_TRADE=0.005               # fraction of equity risked per trade (0.5%)
ATR_PERIOD=14
ATR_STOP_MULT=2.0
TAKE_PROFIT_R=1.5                  # TP as multiple of stop distance (R)
MAX_OPEN_POSITIONS=1

# --- Binance FUTURES TESTNET (crypto trend live-paper; NOT real money) ---
# Create keys at https://testnet.binancefuture.com (login, API Key panel at bottom)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_ENVIRONMENT=TESTNET         # TESTNET only — runner refuses LIVE
BINANCE_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,XRPUSDT,ADAUSDT,SOLUSDT,LTCUSDT,LINKUSDT
BINANCE_TARGET_VOL=0.15
BINANCE_MARK_CHECK_SECS=5            # evaluate stream freshness / drawdown every 5s
BINANCE_MARK_STALE_SECS=15           # block new entries if any 1s mark stream is this old
BINANCE_STOP_PCT=0.20               # per-position stop-loss (exchange-native, reduce-only)
BINANCE_MAX_DRAWDOWN=0.20           # portfolio kill-switch (flatten + halt)
BINANCE_RISK_CHECK_SECS=5           # mark-to-market portfolio drawdown cadence

# --- Optional realism features (all OFF by default; defaults reproduce the headline backtest) ---
# Vol-adaptive stop: stop distance = stop_vol_mult x recent daily vol, clamped.
# Backtest: slightly LOWER drawdown + higher Calmar than a fixed stop. Safe to enable.
BINANCE_USE_VOL_STOP=false
BINANCE_STOP_VOL_MULT=4.0
BINANCE_MIN_STOP_PCT=0.08
BINANCE_MAX_STOP_PCT=0.30
# Native reduce-only volatility trail. The original hard stop stays live. The
# trail arms at entry +/- activation_r * initial hard-stop distance (+1R by
# default), then follows the mark by trailing_vol_mult * recent daily volatility.
# Callback distance is clamped to the configured range and Binance's 0.1%-10% limits.
BINANCE_USE_TRAILING_STOP=false
BINANCE_TRAILING_ACTIVATION_R=1.0
BINANCE_TRAILING_VOL_MULT=3.0
BINANCE_MIN_TRAILING_PCT=0.005
BINANCE_MAX_TRAILING_PCT=0.10
# Flatten all positions on a graceful process stop. Default false = leave positions
# (exchange-native stops still protect them); set true to force-exit on shutdown.
BINANCE_FLATTEN_ON_STOP=false
# Correlation scaling: cut gross exposure when the book gets too correlated (crowded).
# Backtest: small Sharpe gain + lower drawdown. Safe to enable.
BINANCE_USE_CORRELATION_SCALING=false
BINANCE_CORR_WINDOW=90
BINANCE_CORR_THRESHOLD=0.65
BINANCE_CORR_MIN_SCALAR=0.50
# Funding filter: veto/trim entries when the perp funding rate is too expensive.
# Needs live funding polling (fapi premiumIndex). Funding is a REAL cost (~0.15 Sharpe
# drag in backtest) — this tries to avoid the worst of it. Watch on testnet before trusting.
BINANCE_FUNDING_FILTER_ENABLED=false
BINANCE_FUNDING_RATE_LIMIT=0.0010
BINANCE_FUNDING_REFRESH_SECS=3600
# Cost-aware rebalance: skip tiny rebalances whose expected edge < round-trip cost.
# Backtest: ~neutral (cuts churn without hurting returns). Safe to enable.
BINANCE_COST_AWARE_REBALANCE=false
BINANCE_ROUND_TRIP_COST_BPS=8.0
BINANCE_SLIPPAGE_BPS=2.0
# Patient limit entries: post a limit offset_bps inside the touch, wait timeout_secs,
# then fall back to market (if fallback=true). Saves spread when filled. Effect only
# shows on live microstructure (a daily-bar backtest can't see it) — verify on testnet.
BINANCE_USE_PATIENT_LIMIT=false
BINANCE_PATIENT_LIMIT_OFFSET_BPS=2.0
BINANCE_PATIENT_LIMIT_TIMEOUT_SECS=300
BINANCE_PATIENT_LIMIT_MARKET_FALLBACK=true

# --- Companion dashboard / API / Telegram ---
API_HOST=0.0.0.0
API_PORT=8000                      # dashboard at http://<host>:API_PORT/
API_TOKEN=                         # if set, /kill & /resume need ?token=... (set one on a public VPS!)
API_DD_WARN_PCT=0.10               # Telegram alert when drawdown crosses this
API_BOT_DOWN_SECS=600              # alert if no bot heartbeat for this long
TELEGRAM_BOT_TOKEN=                # from @BotFather
TELEGRAM_CHAT_ID=                  # your chat id (message @userinfobot to get it)

# --- Safety ---
DEMO_ONLY=true                     # run_demo.py refuses to start if false/missing
