# Copy to .env and fill in. NEVER commit the real .env.

# --- MetaTrader 5 DEMO account ---
MT5_LOGIN=00000000
MT5_PASSWORD=changeme
MT5_SERVER=YourBroker-Demo          # must be a DEMO server
MT5_TERMINAL_PATH=                  # optional: path to terminal64.exe

# --- Instrument / timeframe ---
TRADING_SYMBOL=EURUSD
BAR_SPEC=15-MINUTE-LAST             # NautilusTrader bar spec

# --- Kronos brain ---
KRONOS_TOKENIZER=NeoQuasar/Kronos-Tokenizer-base
KRONOS_MODEL=NeoQuasar/Kronos-small
KRONOS_DEVICE=cpu                  # cpu | cuda:0
KRONOS_MAX_CONTEXT=512
LOOKBACK=400                       # <= max_context
PRED_LEN=12                        # forecast horizon in bars
SAMPLE_COUNT=10                    # probabilistic sampling paths
KRONOS_T=1.0
KRONOS_TOP_P=0.9

# --- Signal / risk ---
SIGNAL_THRESHOLD_BPS=8             # min expected move over horizon, in basis points, ON TOP of cost
RISK_PER_TRADE=0.005               # fraction of equity risked per trade (0.5%)
ATR_PERIOD=14
ATR_STOP_MULT=2.0
TAKE_PROFIT_R=1.5                  # TP as multiple of stop distance (R)
MAX_OPEN_POSITIONS=1

# --- Binance FUTURES TESTNET (crypto trend live-paper; NOT real money) ---
# Create keys at https://testnet.binancefuture.com (login, API Key panel at bottom)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_ENVIRONMENT=TESTNET         # TESTNET only — runner refuses LIVE
BINANCE_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,XRPUSDT,ADAUSDT,SOLUSDT,LTCUSDT,LINKUSDT
BINANCE_TARGET_VOL=0.15
BINANCE_STOP_PCT=0.20               # per-position stop-loss (exchange-native)
BINANCE_MAX_DRAWDOWN=0.20           # portfolio kill-switch (flatten + halt)

# --- Companion dashboard / API / Telegram ---
API_HOST=0.0.0.0
API_PORT=8000                      # dashboard at http://<host>:API_PORT/
API_TOKEN=                         # if set, /kill & /resume need ?token=... (set one on a public VPS!)
API_DD_WARN_PCT=0.10               # Telegram alert when drawdown crosses this
API_BOT_DOWN_SECS=600              # alert if no bot heartbeat for this long
TELEGRAM_BOT_TOKEN=                # from @BotFather
TELEGRAM_CHAT_ID=                  # your chat id (message @userinfobot to get it)

# --- Safety ---
DEMO_ONLY=true                     # run_demo.py refuses to start if false/missing
